@page
@model PromotorSelection.Pages.Student.PromotorsModel
@{
    Layout = "_StudentLayout";
    ViewData["Title"] = "Lista promotorów";
}

<h1 class="mb-2">Lista promotorów</h1>
<p class="text-muted">
    Przegląd promotorów oraz tematów. Kolumna „Zainteresowanych” bazuje na preferencjach studentów.
</p>

@if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
{
    <div class="alert alert-danger">@Model.ErrorMessage</div>
}

<form method="get" id="promotorsFilterForm" class="row g-2 align-items-end mb-3">
    <div class="col-12 col-md-10">
        <label class="form-label">Szukaj</label>
        <input class="form-control"
               id="qInput"
               name="Q"
               value="@Model.Q"
               autocomplete="off"
               placeholder="Imię, nazwisko, email..." />
    </div>

    <div class="col-12 col-md-2 d-flex gap-2">
        <a class="btn btn-outline-secondary" asp-page="/Student/Promotors">Wyczyść</a>
    </div>

    <input type="hidden" name="Sort" value="@Model.Sort" />
    <input type="hidden" name="Dir" value="@Model.Dir" />
</form>

<div class="mb-3 text-muted">
    Wyniki: <strong>@Model.FilteredCount</strong> / @Model.TotalCount
</div>

<style>
    .sort-link { color: inherit; text-decoration: none; font-weight: 600; }
    .sort-link:hover { text-decoration: underline; }
    .sort-icon { display: inline-block; width: 1.2em; text-align: center; opacity: .7; margin-left: .25rem; }
    tr.promotor-row { cursor: pointer; }
    tr.promotor-row:hover { background: rgba(0,0,0,.03); }
</style>

@if (Model.Promotors.Count == 0)
{
    <p>Brak promotorów do wyświetlenia.</p>
}
else
{
    <table class="table table-striped align-middle">
        <thead>
            <tr>
                <th>
                    <a class="sort-link"
                       asp-page="/Student/Promotors"
                       asp-route-Q="@Model.Q"
                       asp-route-Sort="lastName"
                       asp-route-Dir="@Model.NextDir("lastName")">
                        Promotor <span class="sort-icon">@Model.SortIcon("lastName")</span>
                    </a>
                </th>

                <th>Email</th>

                <th class="text-end">
                    <a class="sort-link"
                       asp-page="/Student/Promotors"
                       asp-route-Q="@Model.Q"
                       asp-route-Sort="limit"
                       asp-route-Dir="@Model.NextDir("limit")">
                        Limit <span class="sort-icon">@Model.SortIcon("limit")</span>
                    </a>
                </th>

                <th class="text-end">
                    <a class="sort-link"
                       asp-page="/Student/Promotors"
                       asp-route-Q="@Model.Q"
                       asp-route-Sort="interested"
                       asp-route-Dir="@Model.NextDir("interested")">
                        Zainteresowanych <span class="sort-icon">@Model.SortIcon("interested")</span>
                    </a>
                </th>

                <th class="text-end">
                    <a class="sort-link"
                       asp-page="/Student/Promotors"
                       asp-route-Q="@Model.Q"
                       asp-route-Sort="free"
                       asp-route-Dir="@Model.NextDir("free")">
                        Wolne <span class="sort-icon">@Model.SortIcon("free")</span>
                    </a>
                </th>

                <th>Tematy</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var p in Model.Promotors)
            {
                var detailsId = $"topics-{p.UserId}";
                <tr class="promotor-row" data-details="@detailsId">
                    <td>
                        <div class="fw-semibold">@p.LastName @p.FirstName</div>
                        <div class="text-muted small">UserId: @p.UserId</div>
                    </td>

                    <td>@p.Email</td>

                    <td class="text-end">@p.StudentLimit</td>

                    <td class="text-end">
                        @if (p.InterestedStudentsCount.HasValue)
                        {
                            @p.InterestedStudentsCount
                        }
                        else
                        {
                            <span class="text-muted">—</span>
                        }
                    </td>

                    <td class="text-end">
                        @if (p.FreeSlots.HasValue)
                        {
                            var free = p.FreeSlots.Value;
                            <span class="badge bg-@(free > 0 ? "success" : "secondary")">@free</span>
                        }
                        else
                        {
                            <span class="text-muted">—</span>
                        }
                    </td>

                    <td>
                        <span class="badge bg-secondary">Tematy: @p.Topics.Count</span>
                    </td>
                </tr>

                <tr id="@detailsId" class="d-none">
                    <td colspan="6">
                        <div class="p-3 border rounded bg-light">
                            <div class="fw-semibold mb-2">Tematy promotora</div>

                            @if (p.Topics.Count == 0)
                            {
                                <div class="text-muted">Brak tematów.</div>
                            }
                            else
                            {
                                <ul class="mb-0">
                                    @foreach (var t in p.Topics)
                                    {
                                        <li class="mb-2">
                                            <div class="fw-semibold">@t.Title</div>
                                            @if (!string.IsNullOrWhiteSpace(t.Description))
                                            {
                                                <div class="text-muted">@t.Description</div>
                                            }
                                        </li>
                                    }
                                </ul>
                            }
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

<script>
    (function () {
        const form = document.getElementById('promotorsFilterForm');
        const input = document.getElementById('qInput');

        if (form && input) {
            window.addEventListener('load', () => {
                input.focus({ preventScroll: true });
                const v = input.value;
                input.setSelectionRange(v.length, v.length);
            });

            let t = null;
            input.addEventListener('input', function () {
                clearTimeout(t);
                t = setTimeout(() => form.requestSubmit(), 250);
            });
        }

        function toggleDetails(detailsRowId) {
            const row = document.getElementById(detailsRowId);
            if (!row) return;
            row.classList.toggle('d-none');
        }

        document.addEventListener('click', function (e) {
            if (e.target.closest('a, button, input, select, textarea, form')) return;

            const promotorRow = e.target.closest('tr.promotor-row');
            if (promotorRow) {
                const detailsId = promotorRow.getAttribute('data-details');
                if (detailsId) toggleDetails(detailsId);
            }
        });
    })();
</script>
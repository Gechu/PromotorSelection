
<ul class="navbar-nav">
    @if (User.Identity?.IsAuthenticated ?? false)
    {
        <li class="nav-item">

            <span class="nav-link text-dark">Witaj, @User.Identity.Name!</span>
        </li>
        <li class="nav-item">
            <form id="logoutForm" class="form-inline" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Page("/Index")">
                <button id="logout" type="submit" class="nav-link btn btn-link text-dark border-0">Wyloguj</button>
            </form>
        </li>
    }
    else
    {
        <li class="nav-item">
            <a class="nav-link text-dark" id="login" asp-page="/Account/Login">Zaloguj się</a>
        </li>
    }
</ul>
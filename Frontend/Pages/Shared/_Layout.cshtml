
<!DOCTYPE html>
<html lang="pl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - PromotorSelection</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/PromotorSelection.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-lg">
                <a class="navbar-brand" asp-page="/Index">PromotorSelection</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            @if (User.Identity?.IsAuthenticated ?? false)
                            {
                                if (User.IsInRole("Admin"))
                                {
                                    <a class="nav-link @(ViewContext.RouteData.Values["page"]?.ToString() == "/Admin/Index" ? "active-nav" : "")" asp-page="/Admin/Index">Home (Admin)</a>
                                }
                                else if (User.IsInRole("Promotor"))
                                {
                                    <a class="nav-link @(ViewContext.RouteData.Values["page"]?.ToString() == "/Promotor/Index" ? "active-nav" : "")" asp-page="/Promotor/Index">Home (Promotor)</a>
                                }
                                else if (User.IsInRole("Student"))
                                {
                                    <a class="nav-link @(ViewContext.RouteData.Values["page"]?.ToString() == "/Student/Index" ? "active-nav" : "")" asp-page="/Student/Index">Home (Student)</a>
                                }
                            }
                            else
                            {
                                <a class="nav-link @(ViewContext.RouteData.Values["page"]?.ToString() == "/Index" ? "active-nav" : "")" asp-page="/Index">Home</a>
                            }
                        </li>
                    </ul>

                    @if (User.Identity?.IsAuthenticated ?? false)
                    {
                        <form asp-page="/Account/Logout" method="post" class="form-inline">
                            <button type="submit" class="btn btn-link text-dark nav-link" style="border:none;">Wyloguj</button>
                        </form>
                    }
                </div>
            </div>
        </nav>
    </header>
    <main role="main" class="flex-grow-1 pb-3">
        <div class="container-lg">
            @RenderBody()
        </div>
    </main>

    <footer class="border-top footer text-muted">
        <div class="container-lg">
            &copy; 2026 - PromotorSelection
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
@page
@model PromotorSelection.Pages.Admin.StudentsModel
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Lista studentów";
}

<h1 class="mb-3">Lista studentów</h1>

@if (!string.IsNullOrWhiteSpace(Model.SuccessMessage))
{
    <div class="alert alert-success">@Model.SuccessMessage</div>
}
@if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
{
    <div class="alert alert-danger">@Model.ErrorMessage</div>
}

<form method="get" id="studentsFilterForm" class="row g-2 align-items-end mb-3">
    <div class="col-12 col-md-10">
        <label class="form-label">Szukaj</label>
        <input class="form-control"
               id="qInput"
               name="Q"
               value="@Model.Q"
               autocomplete="off"
               placeholder="Imię, nazwisko, email, nr albumu, UserId lub TeamId..." />
    </div>

    <div class="col-12 col-md-2 d-flex gap-2">
        <a class="btn btn-outline-secondary"
           asp-page="/Admin/Students">
            Wyczyść
        </a>
    </div>

    <input type="hidden" name="Sort" value="@Model.Sort" />
    <input type="hidden" name="Dir" value="@Model.Dir" />
</form>

<div class="mb-3 text-muted">
    Wyniki: <strong>@Model.FilteredCount</strong> / @Model.TotalCount
    | Solo: <strong>@Model.SoloCount</strong>
    | W zespole: <strong>@Model.InTeamCount</strong>
</div>

<style>
    /* nagłówki sortowania */
    .sort-link {
        color: inherit;
        text-decoration: none;
        font-weight: 600;
    }

        .sort-link:hover {
            text-decoration: underline;
        }

    .sort-icon {
        display: inline-block;
        width: 1.2em;
        text-align: center;
        opacity: .7;
        margin-left: .25rem;
    }
</style>

@if (Model.Students.Count == 0)
{
    <p>Brak studentów do wyświetlenia.</p>
}
else
{
    <table class="table table-striped align-middle">
        <thead>
            <tr>
                <th>UserId</th>

                <th>
                    <a class="sort-link"
                       asp-page="/Admin/Students"
                       asp-route-Q="@Model.Q"
                       asp-route-Sort="lastName"
                       asp-route-Dir="@Model.NextDir("lastName")">
                        Nazwisko <span class="sort-icon">@Model.SortIcon("lastName")</span>
                    </a>
                </th>

                <th>Imię</th>
                <th>Email</th>
                <th>Nr albumu</th>

                <th class="text-end">
                    <a class="sort-link"
                       asp-page="/Admin/Students"
                       asp-route-Q="@Model.Q"
                       asp-route-Sort="grade"
                       asp-route-Dir="@Model.NextDir("grade")">
                        Średnia <span class="sort-icon">@Model.SortIcon("grade")</span>
                    </a>
                </th>

                <th>
                    <a class="sort-link"
                       asp-page="/Admin/Students"
                       asp-route-Q="@Model.Q"
                       asp-route-Sort="team"
                       asp-route-Dir="@Model.NextDir("team")">
                        Zespół <span class="sort-icon">@Model.SortIcon("team")</span>
                    </a>
                </th>

                <th style="width: 220px;">Akcje</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var s in Model.Students)
            {
                <tr data-row="@s.UserId">
                    <td>@s.UserId</td>
                    <td>@s.LastName</td>
                    <td>@s.FirstName</td>
                    <td>@s.Email</td>
                    <td>@s.AlbumNumber</td>

                    <td class="text-end">
                        <span class="grade-view">@s.GradeAverage.ToString("0.00")</span>

                        <form method="post"
                              asp-page-handler="UpdateGrade"
                              class="grade-edit d-none mt-1"
                              style="min-width: 170px;">
                            @Html.AntiForgeryToken()

                            <input type="hidden" name="UserId" value="@s.UserId" />
                            <input type="hidden" name="FirstName" value="@s.FirstName" />
                            <input type="hidden" name="LastName" value="@s.LastName" />
                            <input type="hidden" name="Email" value="@s.Email" />
                            <input type="hidden" name="AlbumNumber" value="@s.AlbumNumber" />

                            <div class="input-group input-group-sm">
                                <input class="form-control"
                                       name="NewGrade"
                                       type="number"
                                       step="0.01"
                                       min="2.0"
                                       max="5.5"
                                       value="@s.GradeAverage.ToString("0.00")" />
                                <button class="btn btn-success" type="submit">Zapisz</button>
                            </div>

                            <button type="button" class="btn btn-link btn-sm p-0 mt-1 cancel-edit">Anuluj</button>
                        </form>
                    </td>

                    <td>
                        @if (s.TeamId == 0)
                        {
                            <span class="badge bg-secondary">solo</span>
                        }
                        else
                        {
                            <span class="badge bg-success">team @s.TeamId</span>
                        }
                    </td>

                    <td>
                        <button type="button" class="btn btn-outline-primary btn-sm start-edit">
                            Edytuj średnią
                        </button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

<script>
    (function () {
        const form = document.getElementById('studentsFilterForm');
        const input = document.getElementById('qInput');

        // live search + focus po reloadzie
        if (form && input) {
            window.addEventListener('load', () => {
                input.focus({ preventScroll: true });
                const v = input.value;
                input.setSelectionRange(v.length, v.length);
            });

            let t = null;
            input.addEventListener('input', function () {
                clearTimeout(t);
                t = setTimeout(() => form.requestSubmit(), 250);
            });
        }

        function showEdit(row) {
            row.querySelector('.grade-view')?.classList.add('d-none');
            row.querySelector('.grade-edit')?.classList.remove('d-none');
            row.querySelector('.start-edit')?.classList.add('d-none');

            const gradeInput = row.querySelector('input[name="NewGrade"]');
            if (gradeInput) {
                gradeInput.focus({ preventScroll: true });
                gradeInput.select();
            }
        }

        function hideEdit(row) {
            row.querySelector('.grade-view')?.classList.remove('d-none');
            row.querySelector('.grade-edit')?.classList.add('d-none');
            row.querySelector('.start-edit')?.classList.remove('d-none');
        }

        document.addEventListener('click', function (e) {
            const startBtn = e.target.closest('.start-edit');
            if (startBtn) {
                const row = startBtn.closest('tr');
                if (row) showEdit(row);
                return;
            }

            const cancelBtn = e.target.closest('.cancel-edit');
            if (cancelBtn) {
                const row = cancelBtn.closest('tr');
                if (row) hideEdit(row);
                return;
            }
        });
    })();
</script>
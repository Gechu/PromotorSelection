@page
@model PromotorSelection.Pages.Admin.StudentsModel
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Lista studentów";
}

<h1 class="mb-3">Lista studentów</h1>

<form method="get" id="studentsFilterForm" class="row g-2 align-items-end mb-3">
    <div class="col-12 col-md-10">
        <label class="form-label">Szukaj</label>
        <input class="form-control"
               id="qInput"
               name="Q"
               value="@Model.Q"
               autocomplete="off"
               placeholder="Imię, nazwisko, email, nr albumu, UserId lub TeamId..." />
    </div>

    <div class="col-12 col-md-2 d-flex gap-2">
        <a class="btn btn-outline-secondary"
           asp-page="/Admin/Students">
            Wyczyść
        </a>
    </div>

    @* utrzymujemy sort w query string *@
    <input type="hidden" name="Sort" value="@Model.Sort" />
    <input type="hidden" name="Dir" value="@Model.Dir" />
</form>

<div class="mb-3 text-muted">
    Wyniki: <strong>@Model.FilteredCount</strong> / @Model.TotalCount
    | Solo: <strong>@Model.SoloCount</strong>
    | W zespole: <strong>@Model.InTeamCount</strong>
</div>

<style>
    /* nagłówki sortowania */
    .sort-link {
        color: inherit;
        text-decoration: none;
        font-weight: 600;
    }
    .sort-link:hover {
        text-decoration: underline;
    }
    .sort-icon {
        display: inline-block;
        width: 1.2em;
        text-align: center;
        opacity: .7;
        margin-left: .25rem;
    }
</style>

@if (Model.Students.Count == 0)
{
    <p>Brak studentów do wyświetlenia.</p>
}
else
{
    <table class="table table-striped align-middle">
        <thead>
            <tr>
                <th>UserId</th>

                <th>
                    <a class="sort-link"
                       asp-page="/Admin/Students"
                       asp-route-Q="@Model.Q"
                       asp-route-Sort="lastName"
                       asp-route-Dir="@Model.NextDir("lastName")">
                        Nazwisko
                        <span class="sort-icon">@Model.SortIcon("lastName")</span>
                    </a>
                </th>

                <th>Imię</th>
                <th>Email</th>
                <th>Nr albumu</th>

                <th class="text-end">
                    <a class="sort-link"
                       asp-page="/Admin/Students"
                       asp-route-Q="@Model.Q"
                       asp-route-Sort="grade"
                       asp-route-Dir="@Model.NextDir("grade")">
                        Średnia
                        <span class="sort-icon">@Model.SortIcon("grade")</span>
                    </a>
                </th>

                <th>
                    <a class="sort-link"
                       asp-page="/Admin/Students"
                       asp-route-Q="@Model.Q"
                       asp-route-Sort="team"
                       asp-route-Dir="@Model.NextDir("team")">
                        Zespół
                        <span class="sort-icon">@Model.SortIcon("team")</span>
                    </a>
                </th>
            </tr>
        </thead>

        <tbody>
            @foreach (var s in Model.Students)
            {
                <tr>
                    <td>@s.UserId</td>
                    <td>@s.LastName</td>
                    <td>@s.FirstName</td>
                    <td>@s.Email</td>
                    <td>@s.AlbumNumber</td>
                    <td class="text-end">@s.GradeAverage.ToString("0.00")</td>
                    <td>
                        @if (s.TeamId == 0)
                        {
                            <span class="badge bg-secondary">solo</span>
                        }
                        else
                        {
                            <span class="badge bg-success">team @s.TeamId</span>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

<script>
    (function () {
        const form = document.getElementById('studentsFilterForm');
        const input = document.getElementById('qInput');
        if (!form || !input) return;

        // 1) Po załadowaniu strony: focus na input i kursor na koniec
        window.addEventListener('load', () => {
            input.focus({ preventScroll: true });
            const v = input.value;
            input.setSelectionRange(v.length, v.length);
        });

        // 2) debounce, żeby nie odświeżać strony co chwilę
        let t = null;
        input.addEventListener('input', function () {
            clearTimeout(t);
            t = setTimeout(() => form.requestSubmit(), 250);
        });
    })();
</script>

<hr class="mt-4" />

<div class="small text-muted">
    <strong>TODO:</strong>
    Po dodaniu endpointu adminowego w backendzie (np. <code>PUT /api/Students/{userId}/grade</code>)
    dodać w tej tabeli możliwość zmiany średniej (inline albo w modalu) dla wybranego studenta.
</div>
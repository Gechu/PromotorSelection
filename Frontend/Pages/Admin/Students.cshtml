@page
@model PromotorSelection.Pages.Admin.StudentsModel
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Lista studentów";
}

<h1 class="mb-2">Lista studentów</h1>
<p class="text-muted">Zarządzanie studentami (dodawanie, edycja, usuwanie) oraz podgląd danych.</p>

@if (!string.IsNullOrWhiteSpace(Model.SuccessMessage))
{
    <div class="alert alert-success">@Model.SuccessMessage</div>
}
@if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
{
    <div class="alert alert-danger">@Model.ErrorMessage</div>
}

<!-- Panel akcji -->
<div class="d-flex flex-wrap gap-2 mb-3">
    <a class="btn btn-primary"
       asp-page="/Admin/Students"
       asp-route-Q="@Model.Q"
       asp-route-Sort="@Model.Sort"
       asp-route-Dir="@Model.Dir"
       asp-route-FormMode="create">
        Dodaj studenta
    </a>

    <button class="btn btn-outline-secondary" disabled title="TODO: w kolejnym kroku podpinamy import CSV">
        Wczytaj z CSV (wkrótce)
    </button>
</div>

@if (Model.FormMode is not null)
{
    <div class="card shadow-sm mb-4">
        <div class="card-header">
            @if (Model.FormMode == "create")
            {
                <span>Dodaj studenta</span>
            }
            else
            {
                <span>Edytuj studenta (UserId: @Model.Form.UserId)</span>
            }
        </div>

        <div class="card-body">
            <form method="post" asp-page-handler="Save" class="row g-3">
                @Html.AntiForgeryToken()

                <input type="hidden" name="Q" value="@Model.Q" />
                <input type="hidden" name="Sort" value="@Model.Sort" />
                <input type="hidden" name="Dir" value="@Model.Dir" />

                <input type="hidden" name="FormMode" value="@Model.FormMode" />
                <input type="hidden" asp-for="Form.UserId" />

                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <div class="col-12 col-md-6">
                    <label class="form-label">Imię</label>
                    <input class="form-control" asp-for="Form.FirstName" />
                    <span class="text-danger" asp-validation-for="Form.FirstName"></span>
                </div>

                <div class="col-12 col-md-6">
                    <label class="form-label">Nazwisko</label>
                    <input class="form-control" asp-for="Form.LastName" />
                    <span class="text-danger" asp-validation-for="Form.LastName"></span>
                </div>

                <div class="col-12 col-md-6">
                    <label class="form-label">Email</label>
                    <input class="form-control" asp-for="Form.Email" />
                    <span class="text-danger" asp-validation-for="Form.Email"></span>
                </div>

                <div class="col-12 col-md-6">
                    <label class="form-label">Nr albumu</label>
                    <input class="form-control" asp-for="Form.AlbumNumber" />
                    <span class="text-danger" asp-validation-for="Form.AlbumNumber"></span>
                </div>

                <div class="col-12 col-md-6">
                    <label class="form-label">Średnia</label>
                    <input class="form-control"
                           asp-for="Form.GradeAverageText"
                           placeholder="np. 4.56"
                           inputmode="decimal" />
                    <div class="form-text">Akceptuje zapis 4.56 i 4,56. Puste = nie zmieniaj (przy edycji).</div>
                    <span class="text-danger" asp-validation-for="Form.GradeAverageText"></span>
                </div>

                <div class="col-12 col-md-6">
                    <label class="form-label">
                        Hasło
                        @if (Model.FormMode == "edit")
                        {
                            <span class="text-muted">(opcjonalnie)</span>
                        }
                    </label>
                    <input class="form-control" asp-for="Form.Password" type="password" autocomplete="new-password" />
                    <div class="form-text">
                        @if (Model.FormMode == "create")
                        {
                            <span>Wymagane przy dodawaniu.</span>
                        }
                        else
                        {
                            <span>Zostaw puste, aby nie zmieniać hasła.</span>
                        }
                    </div>
                    <span class="text-danger" asp-validation-for="Form.Password"></span>
                </div>

                <div class="col-12 d-flex gap-2">
                    <button type="submit" class="btn btn-success">
                        Zapisz
                    </button>

                    <a class="btn btn-outline-secondary"
                       asp-page="/Admin/Students"
                       asp-route-Q="@Model.Q"
                       asp-route-Sort="@Model.Sort"
                       asp-route-Dir="@Model.Dir">
                        Anuluj
                    </a>
                </div>
            </form>
        </div>
    </div>
}

<!-- Filtr / sort -->
<form method="get" id="studentsFilterForm" class="row g-2 align-items-end mb-3">
    <div class="col-12 col-md-10">
        <label class="form-label">Szukaj</label>
        <input class="form-control"
               id="qInput"
               name="Q"
               value="@Model.Q"
               autocomplete="off"
               placeholder="Imię, nazwisko, email, nr albumu, UserId lub TeamId..." />
    </div>

    <div class="col-12 col-md-2 d-flex gap-2">
        <a class="btn btn-outline-secondary"
           asp-page="/Admin/Students">
            Wyczyść
        </a>
    </div>

    <input type="hidden" name="Sort" value="@Model.Sort" />
    <input type="hidden" name="Dir" value="@Model.Dir" />
</form>

<div class="mb-3 text-muted">
    Wyniki: <strong>@Model.FilteredCount</strong> / @Model.TotalCount
    | Solo: <strong>@Model.SoloCount</strong>
    | W zespole: <strong>@Model.InTeamCount</strong>
</div>

<style>
    .sort-link {
        color: inherit;
        text-decoration: none;
        font-weight: 600;
    }

        .sort-link:hover {
            text-decoration: underline;
        }

    .sort-icon {
        display: inline-block;
        width: 1.2em;
        text-align: center;
        opacity: .7;
        margin-left: .25rem;
    }
</style>

@if (Model.Students.Count == 0)
{
    <p>Brak studentów do wyświetlenia.</p>
}
else
{
    <table class="table table-striped align-middle">
        <thead>
            <tr>
                <th>UserId</th>

                <th>
                    <a class="sort-link"
                       asp-page="/Admin/Students"
                       asp-route-Q="@Model.Q"
                       asp-route-Sort="lastName"
                       asp-route-Dir="@Model.NextDir("lastName")">
                        Nazwisko <span class="sort-icon">@Model.SortIcon("lastName")</span>
                    </a>
                </th>

                <th>Imię</th>
                <th>Email</th>
                <th>Nr albumu</th>

                <th class="text-end">
                    <a class="sort-link"
                       asp-page="/Admin/Students"
                       asp-route-Q="@Model.Q"
                       asp-route-Sort="grade"
                       asp-route-Dir="@Model.NextDir("grade")">
                        Średnia <span class="sort-icon">@Model.SortIcon("grade")</span>
                    </a>
                </th>

                <th>
                    <a class="sort-link"
                       asp-page="/Admin/Students"
                       asp-route-Q="@Model.Q"
                       asp-route-Sort="team"
                       asp-route-Dir="@Model.NextDir("team")">
                        Zespół <span class="sort-icon">@Model.SortIcon("team")</span>
                    </a>
                </th>

                <th style="width: 220px;">Akcje</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var s in Model.Students)
            {
                <tr>
                    <td>@s.UserId</td>
                    <td>@s.LastName</td>
                    <td>@s.FirstName</td>
                    <td>@s.Email</td>
                    <td>@s.AlbumNumber</td>

                    <td class="text-end">@s.GradeAverage.ToString("0.00")</td>

                    <td>
                        @if (s.TeamId == 0)
                        {
                            <span class="badge bg-secondary">solo</span>
                        }
                        else
                        {
                            <span class="badge bg-success">team @s.TeamId</span>
                        }
                    </td>

                    <td class="d-flex gap-2">
                        <a class="btn btn-outline-primary btn-sm"
                           asp-page="/Admin/Students"
                           asp-route-Q="@Model.Q"
                           asp-route-Sort="@Model.Sort"
                           asp-route-Dir="@Model.Dir"
                           asp-route-FormMode="edit"
                           asp-route-Id="@s.UserId">
                            Edytuj
                        </a>

                        <form method="post" asp-page-handler="Delete"
                              onsubmit="return confirm('Usunąć studenta (UserId: @s.UserId)? Operacja jest nieodwracalna.');">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="Id" value="@s.UserId" />
                            <input type="hidden" name="Q" value="@Model.Q" />
                            <input type="hidden" name="Sort" value="@Model.Sort" />
                            <input type="hidden" name="Dir" value="@Model.Dir" />
                            <button type="submit" class="btn btn-outline-danger btn-sm">
                                Usuń
                            </button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

<script>
    (function () {
        const form = document.getElementById('studentsFilterForm');
        const input = document.getElementById('qInput');

        if (form && input) {
            window.addEventListener('load', () => {
                input.focus({ preventScroll: true });
                const v = input.value;
                input.setSelectionRange(v.length, v.length);
            });

            let t = null;
            input.addEventListener('input', function () {
                clearTimeout(t);
                t = setTimeout(() => form.requestSubmit(), 250);
            });
        }
    })();
</script>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
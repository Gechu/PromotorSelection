@page
@model PromotorSelection.Pages.Admin.ReportsModel
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Raporty";
}

<h1 class="mb-2">Raporty</h1>
<p class="text-muted">Finalizacja przydziału oraz eksport raportów PDF/XLSX.</p>

@if (!string.IsNullOrWhiteSpace(Model.SuccessMessage))
{
    <div class="alert alert-success">@Model.SuccessMessage</div>
}
@if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
{
    <div class="alert alert-danger">@Model.ErrorMessage</div>
}

<div class="row g-3">
    <!-- 1) Status tury -->
    <div class="col-12 col-lg-6">
        <div class="card shadow-sm">
            <div class="card-header">Status tury</div>
            <div class="card-body">
                @if (Model.Status is null)
                {
                    <div class="text-muted">Brak danych (endpoint api/Schedules nie zwrócił odpowiedzi).</div>
                }
                else
                {
                    <div class="mb-2">
                        <span class="badge bg-@(Model.Status.IsActive ? "success" : "secondary")">
                            @(Model.Status.IsActive ? "Aktywna" : "Nieaktywna")
                        </span>
                    </div>

                    <div class="mb-3">@((Model.Status.Message ?? "—"))</div>

                    <dl class="row mb-0">
                        <dt class="col-5 text-muted">Start</dt>
                        <dd class="col-7">@(Model.Status.StartDate?.ToString("yyyy-MM-dd HH:mm") ?? "—")</dd>

                        <dt class="col-5 text-muted">Koniec</dt>
                        <dd class="col-7">@(Model.Status.EndDate?.ToString("yyyy-MM-dd HH:mm") ?? "—")</dd>

                        @if (Model.Status.IsActive && Model.TimeToEndDisplay is not null)
                        {
                            <dt class="col-5 text-muted">Pozostało</dt>
                            <dd class="col-7">@Model.TimeToEndDisplay</dd>
                        }
                    </dl>

                    <div class="mt-3">
                        <a class="btn btn-outline-primary" asp-page="/Admin/Schedule">Ustaw harmonogram</a>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- 2) Uruchom przydział -->
    <div class="col-12 col-lg-6">
        <div class="card shadow-sm">
            <div class="card-header">Przydział</div>
            <div class="card-body">
                <p class="mb-3">
                    Przydział tworzy wyniki na podstawie preferencji i limitów promotorów.
                    Można go uruchomić dopiero po zakończeniu tury wyborów.
                </p>

                @if (!Model.HasSchedule)
                {
                    <div class="alert alert-warning mb-3">
                        Harmonogram nie jest ustawiony. Najpierw ustaw start i koniec tury.
                    </div>
                }
                else if (!Model.CanRunAllocation)
                {
                    <div class="alert alert-info mb-3">
                        Przydział będzie dostępny po zakończeniu tury (po dacie końcowej).
                    </div>
                }

                <form method="post" asp-page-handler="RunAllocation"
                      onsubmit="return confirm('Na pewno uruchomić przydział? Operacja tworzy wyniki przydziału (i może nadpisać poprzednie wyniki).');">
                    @Html.AntiForgeryToken()

                    <button type="submit"
                            class="btn btn-outline-danger"
                            disabled="@(!Model.CanRunAllocation)">
                        Uruchom przydział
                    </button>
                </form>

                <div class="small text-muted mt-2">
                    Jeśli przydział nie jest dostępny, sprawdź datę zakończenia tury w harmonogramie.
                </div>
            </div>
        </div>
    </div>
</div>

<!-- 3) Statystyki (po przydziale) -->
@if (Model.Stats is not null)
{
    <div class="row g-3 mt-1">
        <div class="col-12">
            <div class="card shadow-sm">
                <div class="card-header">Statystyki (po przydziale)</div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-12 col-md-4">
                            <div class="border rounded p-3">
                                <div class="text-muted">Liczba zespołów</div>
                                <div class="fs-3 fw-semibold">@Model.Stats.TotalTeams</div>
                            </div>
                        </div>
                        <div class="col-12 col-md-4">
                            <div class="border rounded p-3">
                                <div class="text-muted">Studenci solo</div>
                                <div class="fs-3 fw-semibold">@Model.Stats.FreelancersCount</div>
                            </div>
                        </div>
                        <div class="col-12 col-md-4">
                            <div class="border rounded p-3">
                                <div class="text-muted">Studenci bez preferencji</div>
                                <div class="fs-3 fw-semibold">@Model.Stats.IdleStudentsCount</div>
                            </div>
                        </div>
                    </div>

                    <hr />

                    <div class="fw-semibold mb-2">Zainteresowanie promotorami (na podstawie preferencji)</div>

                    @if (Model.Stats.PromotorOccupancy is null || Model.Stats.PromotorOccupancy.Count == 0)
                    {
                        <div class="text-muted">Brak danych o promotorach.</div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-sm table-striped align-middle mb-0">
                                <thead>
                                    <tr>
                                        <th>Promotor</th>
                                        <th class="text-end">Limit</th>
                                        <th class="text-end">Ilu studentów wybrało</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var p in Model.Stats.PromotorOccupancy
                                                                .OrderByDescending(x => x.InterestedStudentsCount)
                                                                .ThenBy(x => x.LastName)
                                                                .ThenBy(x => x.FirstName))
                                    {
                                        <tr>
                                            <td>@p.LastName @p.FirstName <span class="text-muted">(@p.PromotorId)</span></td>
                                            <td class="text-end">@p.StudentLimit</td>
                                            <td class="text-end">@p.InterestedStudentsCount</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }

                    <div class="small text-muted mt-2">
                        Uwaga: to są statystyki zainteresowania z preferencji, a nie wynik finalnego przydziału.
                    </div>
                </div>
            </div>
        </div>
    </div>
}

<!-- 4) Eksport (dopiero po przydziale => po pokazaniu statystyk) -->
@if (Model.Stats is not null)
{
    <div class="row g-3 mt-1">
        <div class="col-12">
            <div class="card shadow-sm">
                <div class="card-header">Eksport raportów</div>
                <div class="card-body">
                    <p class="mb-3">
                        Raporty PDF i Excel są generowane na podstawie wyników przydziału (Assignments).
                    </p>

                    <div class="d-flex flex-wrap gap-2">
                        <a class="btn btn-danger"
                           asp-page="/Admin/Reports"
                           asp-page-handler="Pdf">
                            Pobierz PDF (.pdf)
                        </a>

                        <a class="btn btn-success"
                           asp-page="/Admin/Reports"
                           asp-page-handler="Excel">
                            Pobierz Excel (.xlsx)
                        </a>
                    </div>

                    <hr />

                    <div class="small text-muted">
                        Excel zawiera: (1) listę wszystkich studentów z przypisanym promotorem, (2) podsumowanie obłożenia promotorów (limit/zajęte/wolne).
                        PDF zawiera analogiczne podsumowanie i listę.
                    </div>
                </div>
            </div>
        </div>
    </div>
}
@page
@model PromotorSelection.Pages.Admin.PromotorsModel
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Lista promotorów";
}

<h1 class="mb-2">Lista promotorów</h1>
<p class="text-muted">Zarządzanie promotorami (dodawanie, edycja, usuwanie) oraz podgląd tematów.</p>

@if (!string.IsNullOrWhiteSpace(Model.SuccessMessage))
{
    <div class="alert alert-success">@Model.SuccessMessage</div>
}
@if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
{
    <div class="alert alert-danger">@Model.ErrorMessage</div>
}

<!-- Panel akcji -->
<div class="d-flex flex-wrap gap-2 mb-3">
    <a class="btn btn-primary"
       asp-page="/Admin/Promotors"
       asp-route-Q="@Model.Q"
       asp-route-Sort="@Model.Sort"
       asp-route-Dir="@Model.Dir"
       asp-route-FormMode="create">
        Dodaj promotora
    </a>
</div>

@if (Model.FormMode is not null)
{
    <div class="card shadow-sm mb-4">
        <div class="card-header">
            @if (Model.FormMode == "create")
            {
                <span>Dodaj promotora</span>
            }
            else
            {
                <span>Edytuj promotora (UserId: @Model.Form.UserId)</span>
            }
        </div>

        <div class="card-body">
            <form method="post" asp-page-handler="Save" class="row g-3">
                @Html.AntiForgeryToken()

                <input type="hidden" name="Q" value="@Model.Q" />
                <input type="hidden" name="Sort" value="@Model.Sort" />
                <input type="hidden" name="Dir" value="@Model.Dir" />

                <input type="hidden" name="FormMode" value="@Model.FormMode" />
                <input type="hidden" asp-for="Form.UserId" />

                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <div class="col-12 col-md-6">
                    <label class="form-label">Imię</label>
                    <input class="form-control" asp-for="Form.FirstName" />
                    <span class="text-danger" asp-validation-for="Form.FirstName"></span>
                </div>

                <div class="col-12 col-md-6">
                    <label class="form-label">Nazwisko</label>
                    <input class="form-control" asp-for="Form.LastName" />
                    <span class="text-danger" asp-validation-for="Form.LastName"></span>
                </div>

                <div class="col-12 col-md-6">
                    <label class="form-label">Email</label>
                    <input class="form-control" asp-for="Form.Email" />
                    <span class="text-danger" asp-validation-for="Form.Email"></span>
                </div>

                <div class="col-12 col-md-6">
                    <label class="form-label">Limit studentów</label>
                    <input class="form-control"
                           asp-for="Form.StudentLimit"
                           type="number"
                           min="0"
                           step="1" />
                    <span class="text-danger" asp-validation-for="Form.StudentLimit"></span>
                </div>

                <div class="col-12">
                    <label class="form-label">
                        Hasło
                        @if (Model.FormMode == "edit")
                        {
                            <span class="text-muted">(opcjonalnie)</span>
                        }
                    </label>
                    <input class="form-control" asp-for="Form.Password" type="password" autocomplete="new-password" />
                    <div class="form-text">
                        @if (Model.FormMode == "create")
                        {
                            <span>Wymagane przy dodawaniu promotora.</span>
                        }
                        else
                        {
                            <span>Zostaw puste, aby nie zmieniać hasła.</span>
                        }
                    </div>
                    <span class="text-danger" asp-validation-for="Form.Password"></span>
                </div>

                <div class="col-12 d-flex gap-2">
                    <button type="submit" class="btn btn-success">Zapisz</button>

                    <a class="btn btn-outline-secondary"
                       asp-page="/Admin/Promotors"
                       asp-route-Q="@Model.Q"
                       asp-route-Sort="@Model.Sort"
                       asp-route-Dir="@Model.Dir">
                        Anuluj
                    </a>
                </div>
            </form>
        </div>
    </div>
}

<!-- Filtr / sort -->
<form method="get" id="promotorsFilterForm" class="row g-2 align-items-end mb-3">
    <div class="col-12 col-md-10">
        <label class="form-label">Szukaj</label>
        <input class="form-control"
               id="qInput"
               name="Q"
               value="@Model.Q"
               autocomplete="off"
               placeholder="Imię, nazwisko, email, UserId lub limit..." />
    </div>

    <div class="col-12 col-md-2 d-flex gap-2">
        <a class="btn btn-outline-secondary"
           asp-page="/Admin/Promotors">
            Wyczyść
        </a>
    </div>

    <input type="hidden" name="Sort" value="@Model.Sort" />
    <input type="hidden" name="Dir" value="@Model.Dir" />
</form>

<div class="mb-3 text-muted">
    Wyniki: <strong>@Model.FilteredCount</strong> / @Model.TotalCount
</div>

@if (Model.Promotors.Count == 0)
{
    <p>Brak promotorów do wyświetlenia.</p>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped align-middle">
            <thead>
                <tr>
                    <th>UserId</th>

                    <th>
                        <a class="sort-link"
                           asp-page="/Admin/Promotors"
                           asp-route-Q="@Model.Q"
                           asp-route-Sort="lastName"
                           asp-route-Dir="@Model.NextDir("lastName")">
                            Nazwisko <span class="sort-icon">@Model.SortIcon("lastName")</span>
                        </a>
                    </th>

                    <th>Imię</th>
                    <th>Email</th>

                    <th class="text-end">
                        <a class="sort-link"
                           asp-page="/Admin/Promotors"
                           asp-route-Q="@Model.Q"
                           asp-route-Sort="limit"
                           asp-route-Dir="@Model.NextDir("limit")">
                            Limit <span class="sort-icon">@Model.SortIcon("limit")</span>
                        </a>
                    </th>

                    <th>Tematy</th>
                    <th style="width: 260px;">Akcje</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var p in Model.Promotors)
                {
                    var detailsId = $"topics-{p.UserId}";

                    <tr class="promotor-row" data-details="@detailsId">
                        <td>@p.UserId</td>
                        <td>@p.LastName</td>
                        <td>@p.FirstName</td>
                        <td>@p.Email</td>
                        <td class="text-end">@p.StudentLimit</td>
                        <td><span class="badge bg-secondary">Tematy: @p.Topics.Count</span></td>

                        <td class="d-flex gap-2">
                            <a class="btn btn-outline-primary btn-sm"
                               asp-page="/Admin/Promotors"
                               asp-route-Q="@Model.Q"
                               asp-route-Sort="@Model.Sort"
                               asp-route-Dir="@Model.Dir"
                               asp-route-FormMode="edit"
                               asp-route-Id="@p.UserId">
                                Edytuj
                            </a>

                            <form method="post" asp-page-handler="Delete"
                                  onsubmit="return confirm('Usunąć promotora (UserId: @p.UserId)? Operacja jest nieodwracalna.');">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="Id" value="@p.UserId" />
                                <input type="hidden" name="Q" value="@Model.Q" />
                                <input type="hidden" name="Sort" value="@Model.Sort" />
                                <input type="hidden" name="Dir" value="@Model.Dir" />
                                <button type="submit" class="btn btn-outline-danger btn-sm">Usuń</button>
                            </form>
                        </td>
                    </tr>

                    <tr id="@detailsId" class="d-none">
                        <td colspan="7">
                            <div class="p-3 border rounded bg-light">
                                <div class="fw-semibold mb-2">Tematy promotora</div>

                                @if (p.Topics.Count == 0)
                                {
                                    <div class="text-muted">Brak tematów.</div>
                                }
                                else
                                {
                                    <ul class="mb-0">
                                        @foreach (var t in p.Topics)
                                        {
                                            <li class="mb-2">
                                                <div class="fw-semibold">@t.Title</div>
                                                @if (!string.IsNullOrWhiteSpace(t.Description))
                                                {
                                                    <div class="text-muted">@t.Description</div>
                                                }
                                            </li>
                                        }
                                    </ul>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

<script>
    (function () {
        const form = document.getElementById('promotorsFilterForm');
        const input = document.getElementById('qInput');

        if (form && input) {
            window.addEventListener('load', () => {
                input.focus({ preventScroll: true });
                const v = input.value;
                input.setSelectionRange(v.length, v.length);
            });

            let t = null;
            input.addEventListener('input', function () {
                clearTimeout(t);
                t = setTimeout(() => form.requestSubmit(), 250);
            });
        }

        function toggleDetails(detailsRowId) {
            const row = document.getElementById(detailsRowId);
            if (!row) return;
            row.classList.toggle('d-none');
        }

        document.addEventListener('click', function (e) {
            if (e.target.closest('a, button, input, select, textarea, form')) return;

            const promotorRow = e.target.closest('tr.promotor-row');
            if (promotorRow) {
                const detailsId = promotorRow.getAttribute('data-details');
                if (detailsId) toggleDetails(detailsId);
            }
        });
    })();
</script>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
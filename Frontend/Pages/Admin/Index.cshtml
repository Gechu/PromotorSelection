@page
@model PromotorSelection.Pages.Admin.IndexModel
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Panel administratora";
}

<h1 class="mb-2">Panel administratora</h1>
<p class="text-muted">Zarządzanie systemem wyboru promotorów.</p>

@if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
{
    <div class="alert alert-danger">@Model.ErrorMessage</div>
}

<div class="row g-3 mb-4">
    <div class="col-6 col-md-3">
        <div class="card shadow-sm stat-card">
            <div class="card-body">
                <div class="text-muted"><i class="bi bi-people"></i> Studenci</div>
                <div class="display-6">@Model.StudentsCount</div>
            </div>
        </div>
    </div>

    <div class="col-6 col-md-3">
        <div class="card shadow-sm stat-card-success">
            <div class="card-body">
                <div class="text-muted"><i class="bi bi-person-badge"></i> Promotorzy</div>
                <div class="display-6">@Model.PromotorsCount</div>
            </div>
        </div>
    </div>

    <div class="col-6 col-md-3">
        <div class="card shadow-sm stat-card-warning">
            <div class="card-body">
                <div class="text-muted"><i class="bi bi-diagram-3"></i> Zespoły</div>
                <div class="display-6">@Model.TeamsCount</div>
            </div>
        </div>
    </div>

    <div class="col-6 col-md-3">
        <div class="card shadow-sm stat-card-danger">
            <div class="card-body">
                <div class="text-muted"><i class="bi bi-journal-text"></i> Tematy</div>
                <div class="display-6">@Model.TopicsCount</div>
            </div>
        </div>
    </div>
</div>

<div class="row g-3">
    <div class="col-12 col-lg-6">
        <div class="card shadow-sm">
            <div class="card-header">Status harmonogramu / tury</div>
            <div class="card-body">
                @if (Model.ScheduleStatus is null)
                {
                    <div class="text-muted">Brak danych o statusie (endpoint api/Schedules nie zwrócił odpowiedzi).</div>
                }
                else
                {
                    <div class="mb-2">
                        <span class="badge bg-@(Model.ScheduleStatus.IsActive ? "success" : "secondary")">
                            @(Model.ScheduleStatus.IsActive ? "Aktywne" : "Nieaktywne")
                        </span>
                    </div>

                    <div class="mb-2">@((Model.ScheduleStatus.Message ?? "—"))</div>

                    <dl class="row mb-0">
                        <dt class="col-5 text-muted">Start</dt>
                        <dd class="col-7">
                            @(Model.ScheduleStatus.StartDate?.ToString("yyyy-MM-dd HH:mm") ?? "—")
                        </dd>

                        <dt class="col-5 text-muted">Koniec</dt>
                        <dd class="col-7">
                            @(Model.ScheduleStatus.EndDate?.ToString("yyyy-MM-dd HH:mm") ?? "—")
                        </dd>

                        @if (Model.ScheduleStatus.IsActive && Model.TimeToEndDisplay is not null)
                        {
                            <dt class="col-5 text-muted">Pozostało</dt>
                            <dd class="col-7">@Model.TimeToEndDisplay</dd>
                        }
                    </dl>

                    <div class="mt-3">
                        <a class="btn btn-outline-primary" asp-page="/Admin/Schedule">Przejdź do harmonogramu</a>
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="col-12 col-lg-6">
        <div class="card shadow-sm">
            <div class="card-header">Alerty</div>
            <div class="card-body">
                @if (Model.Alerts.Count == 0)
                {
                    <div class="text-muted">Brak alertów — wygląda OK.</div>
                }
                else
                {
                    foreach (var a in Model.Alerts)
                    {
                        <div class="alert alert-@a.Level mb-2">
                            <div class="fw-semibold">@a.Title</div>
                            <div>@a.Details</div>
                        </div>
                    }
                }
            </div>
        </div>
    </div>
</div>